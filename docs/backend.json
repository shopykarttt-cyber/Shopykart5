
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A grocery product item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "unit": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "number" },
        "discount": { "type": "string" }
      },
      "required": ["name", "price", "unit", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["name"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupons",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["fixed", "percentage"] },
        "value": { "type": "number" },
        "minOrder": { "type": "number" },
        "description": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" }
      },
      "required": ["code", "discountType", "value"]
    },
    "Customer": {
      "title": "Customer",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "totalOrders": { "type": "number" },
        "totalSpent": { "type": "number" },
        "joinedAt": { "type": "string", "format": "date" }
      },
      "required": ["name", "email"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Push notification logs",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" },
        "target": { "type": "string", "enum": ["all", "segments"] }
      },
      "required": ["title", "body"]
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store for grocery products"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Store for categories"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Store for coupons"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Store for customer profiles"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Store for notification logs"
    }
  }
}
