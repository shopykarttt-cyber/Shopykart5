
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A grocery product item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "mrp": { "type": "number", "description": "Market Retail Price" },
        "price": { "type": "number", "description": "Discounted Sale Price" },
        "unit": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isTopRated": { "type": "boolean", "default": false },
        "mfgDate": { "type": "string", "format": "date" },
        "expiryDate": { "type": "string", "format": "date" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "mrp", "price", "unit", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Promotional banners for home screen",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Processing", "Shipped", "Delivered", "Cancelled"] },
        "address": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupons",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["fixed", "percentage"] },
        "value": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "discountType", "value"]
    },
    "Customer": {
      "title": "Customer",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "totalOrders": { "type": "number" },
        "totalSpent": { "type": "number" },
        "joinedAt": { "type": "string", "format": "date" }
      },
      "required": ["name", "email"]
    },
    "Zone": {
      "title": "Zone",
      "description": "Delivery zones with boundary points",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "pincode": { "type": "string" },
        "points": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "pincode"]
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store for grocery products"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Store for categories"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Store for promotional banners"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Store for customer orders"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Store for coupons"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Store for customer profiles"
    },
    "/zones/{zoneId}": {
      "schema": "Zone",
      "description": "Store for delivery zones"
    }
  }
}
